# Copy to .env — VITE_* values are inlined when you run npm run build.
VITE_SUPABASE_URL=https://piolbedugsubngftsrkm.supabase.co
VITE_SUPABASE_ANON_KEY=

# AI (OpenRouter) — bundled into the app; anyone can extract it from the APK.
VITE_OPENROUTER_API_KEY=
# Optional overrides:
# VITE_OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# VITE_OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001

# Feedback (Web3Forms)
VITE_WEB3FORMS_ACCESS_KEY=

# Cloudinary (Profile Image Uploads) — https://cloudinary.com
# Sign up, create unsigned upload preset "nutriscan_profiles"
VITE_CLOUDINARY_CLOUD_NAME=dqnzrkhol
VITE_CLOUDINARY_UPLOAD_PRESET=nutriscan_profiles

